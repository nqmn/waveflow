#!/usr/bin/env python3
"""
RISNet CLI - Executable wrapper script

This allows running RISNet with:
  risnet --topology examples/json_topologies/example_1_simple.json list
  risnet add ap
  risnet list
  etc.
"""

import sys
import os
from pathlib import Path

# Get the directory where this script is located
script_dir = Path(__file__).parent.absolute()

# Add project root to Python path (parent of bin directory)
project_root = script_dir.parent
sys.path.insert(0, str(project_root))

# Import and run main
from main import main

if __name__ == '__main__':
    sys.exit(main())
