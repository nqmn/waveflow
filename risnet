#!/usr/bin/env python3
"""
RISNet Command-Line Interface

Usage:
    risnet --help              Show help
    risnet --version           Show version
    risnet cli                 Launch interactive CLI
    risnet example_1           Run example 1 (simple network)
    risnet example_2           Run example 2 (topology)
    risnet example_3           Run example 3 (custom topology)
    risnet example_4           Run example 4 (obstacles)
    risnet example_5           Run example 5 (context manager)
    risnet example_6           Run example 6 (batch testing)
    risnet example_7           Run example 7 (interactive CLI)
    risnet examples            Run all examples
"""

import sys
import os
import importlib.util
from pathlib import Path

__version__ = "2.0"

def show_help():
    """Show help message"""
    print(__doc__)

def show_version():
    """Show version"""
    print(f"RISNet v{__version__}")

def run_cli():
    """Launch interactive CLI"""
    from risnet import RISnet
    from risnet_cli import RISnetCLI

    net = RISnet()
    cli = RISnetCLI(net)
    try:
        cli.cmdloop()
    except KeyboardInterrupt:
        print("\n\nExiting...")

def run_example(example_num):
    """Run a specific example"""
    example_name = f"example_{example_num}"
    examples_dir = Path(__file__).parent / "examples"

    # Map short names to full filenames
    example_map = {
        "1": "example_1_simple.py",
        "2": "example_2_topology.py",
        "3": "example_3_custom_topology.py",
        "4": "example_4_obstacles.py",
        "5": "example_5_context_manager.py",
        "6": "example_6_batch_testing.py",
        "7": "example_interactive_cli.py",
    }

    if example_num not in example_map:
        print(f"Error: Unknown example '{example_num}'")
        print("Available: 1, 2, 3, 4, 5, 6, 7, examples")
        return False

    example_file = examples_dir / example_map[example_num]

    if not example_file.exists():
        print(f"Error: Example file not found: {example_file}")
        return False

    # Load and run the example
    spec = importlib.util.spec_from_file_location(f"example_{example_num}", example_file)
    module = importlib.util.module_from_spec(spec)

    try:
        spec.loader.exec_module(module)

        # Run the example
        if hasattr(module, 'run'):
            module.run()
        else:
            print(f"Warning: {example_file.name} has no run() function")
            return False

        return True
    except Exception as e:
        print(f"Error running example: {e}")
        import traceback
        traceback.print_exc()
        return False

def run_all_examples():
    """Run all examples"""
    examples_dir = Path(__file__).parent / "examples"
    examples = ["1", "2", "3", "4", "5", "6"]

    print("\n" + "="*60)
    print("RISNet - Running All Examples")
    print("="*60)

    success_count = 0
    for example_num in examples:
        try:
            if run_example(example_num):
                success_count += 1
        except Exception as e:
            print(f"Error in example {example_num}: {e}")

    print("\n" + "="*60)
    print(f"Completed: {success_count}/{len(examples)} examples successful")
    print("="*60 + "\n")

def run_file(filepath):
    """Run a Python file directly"""
    filepath = Path(filepath)

    if not filepath.exists():
        print(f"Error: File not found: {filepath}")
        return False

    if not filepath.suffix == '.py':
        print(f"Error: File must be a Python file (.py): {filepath}")
        return False

    # Load and run the file
    spec = importlib.util.spec_from_file_location("example_module", filepath)
    module = importlib.util.module_from_spec(spec)

    try:
        spec.loader.exec_module(module)

        # Run the example
        if hasattr(module, 'run'):
            module.run()
        else:
            print(f"Warning: {filepath.name} has no run() function")
            return False

        return True
    except Exception as e:
        print(f"Error running file: {e}")
        import traceback
        traceback.print_exc()
        return False

def main():
    """Main entry point"""
    if len(sys.argv) < 2:
        show_help()
        return

    command = sys.argv[1].lower()

    if command in ["--help", "-h", "help"]:
        show_help()
    elif command in ["--version", "-v", "version"]:
        show_version()
    elif command == "cli":
        run_cli()
    elif command == "examples":
        run_all_examples()
    elif command.startswith("example_"):
        example_num = command.split("_")[1]
        run_example(example_num)
    elif "/" in command or "\\" in command or command.endswith(".py"):
        # It's a file path
        run_file(command)
    else:
        print(f"Error: Unknown command '{command}'")
        print("Use 'risnet --help' for usage information")
        sys.exit(1)

if __name__ == '__main__':
    main()
